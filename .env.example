# ──────────────────────────────────────────────────────────
# Nexus POS — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────────────

# Flask
SECRET_KEY=your-secret-key-change-this-in-production
FLASK_ENV=development

# Database
# SQLite (development): leave DATABASE_URL unset — defaults to ./database.db
# PostgreSQL (production):
DATABASE_URL=postgresql://postgres:pospassword@localhost:5432/posdb
POSTGRES_PASSWORD=pospassword

# Public URL for M-Pesa callbacks (must be HTTPS in production)
APP_BASE_URL=http://localhost:5000

# M-Pesa Daraja API (Safaricom)
# Set MPESA_ENABLED=true and fill credentials for live payments
MPESA_ENABLED=false
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline

# Super admin (created by: flask init-db)
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=admin123

# Subscription period (days)
SUBSCRIPTION_PERIOD_DAYS=30
